#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${TMPDIR:-/tmp}/catcopy-${USER:-user}"

BACKEND="auto"
DESTINATION="auto"
REMOTE_HOST=""
SHOW_BACKENDS=0

DEFAULT_PRIORITY="wl-copy,xclip,xsel,pbcopy"
CATCOPY_PRIORITY="${CATCOPY_PRIORITY:-$DEFAULT_PRIORITY}"

DEFAULT_REMOTE_DISPLAY="${C_REMOTE_DISPLAY:-:0.0}"
DEFAULT_REMOTE_SESSION="${C_REMOTE_SESSION:-x11}"

log_message() {
  if [[ "$DESTINATION" == "stdout" ]]; then
    echo "$*" >&2
  else
    echo "$*"
  fi
}

backend_available() {
  command -v "$1" >/dev/null 2>&1
}

backend_allowed_by_environment() {
  local backend="$1"

  case "$backend" in
    wl-copy)
      [[ -n "${WAYLAND_DISPLAY:-}" ]]
      ;;
    xclip|xsel)
      [[ -n "${DISPLAY:-}" ]]
      ;;
    pbcopy)
      true
      ;;
    *)
      false
      ;;
  esac
}

backend_command() {
  case "$1" in
    wl-copy)
      wl-copy
      ;;
    xclip)
      pkill -f "^catcopy-xclip$" 2>/dev/null || true
      sleep 0.05
      exec -a catcopy-xclip xclip -selection clipboard
      ;;
    xsel)
      xsel --clipboard --input
      ;;
    pbcopy)
      pbcopy
      ;;
    *)
      echo "ERROR: unsupported clipboard backend: $1" >&2
      echo "Supported backends: auto, wl-copy, xclip, xsel, pbcopy" >&2
      exit 1
      ;;
  esac
}

select_auto_backend() {
  local priority="${CATCOPY_PRIORITY:-$DEFAULT_PRIORITY}"
  local backend

  IFS=',' read -ra backends <<< "$priority"

  for backend in "${backends[@]}"; do
    backend="${backend//[[:space:]]/}"
    [[ -n "$backend" ]] || continue

    case "$backend" in
      wl-copy|xclip|xsel|pbcopy)
        ;;
      *)
        echo "ERROR: unsupported backend in CATCOPY_PRIORITY: $backend" >&2
        echo "Supported backends: wl-copy, xclip, xsel, pbcopy" >&2
        exit 1
        ;;
    esac

    if backend_allowed_by_environment "$backend" && backend_available "$backend"; then
      echo "$backend"
      return 0
    fi
  done

  return 1
}

clipboard_copy() {
  local selected="$BACKEND"

  if [[ "$selected" == "auto" ]]; then
    if ! selected="$(select_auto_backend)"; then
      echo "ERROR: no supported clipboard backend found." >&2
      echo "Use --stdout for terminal output, or install/configure a clipboard backend." >&2
      echo "Detected DISPLAY=${DISPLAY:-unset}, WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-unset}" >&2
      echo "CATCOPY_PRIORITY=${CATCOPY_PRIORITY:-unset}" >&2
      exit 1
    fi
  fi

  if ! backend_available "$selected"; then
    echo "ERROR: backend not found: $selected" >&2
    exit 1
  fi

  if ! backend_allowed_by_environment "$selected"; then
    echo "ERROR: backend not usable in this environment: $selected" >&2
    echo "Detected DISPLAY=${DISPLAY:-unset}, WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-unset}" >&2
    exit 1
  fi

  backend_command "$selected"
}

is_local_target() {
  local host="$1"

  [[ "$host" == "localhost" || "$host" == "127.0.0.1" || "$host" == "$(hostname)" ]]
}

copy_payload_file() {
  local payload="$1"

  case "$DESTINATION" in
    stdout)
      cat "$payload"
      ;;
    clipboard)
      clipboard_copy < "$payload"
      log_message "Copied to clipboard"
      ;;
    remote)
      if [[ -z "$REMOTE_HOST" ]]; then
        echo "ERROR: remote destination selected without host" >&2
        exit 1
      fi

      if is_local_target "$REMOTE_HOST"; then
        clipboard_copy < "$payload"
        log_message "Copied to local clipboard: $REMOTE_HOST"
      else
        ssh -o BatchMode=yes "$REMOTE_HOST" \
          "DISPLAY=${DEFAULT_REMOTE_DISPLAY} XDG_SESSION_TYPE=${DEFAULT_REMOTE_SESSION} c --clipboard" < "$payload"
        log_message "Copied to remote clipboard: $REMOTE_HOST"
      fi
      ;;
    auto)
      if select_auto_backend >/dev/null 2>&1; then
        clipboard_copy < "$payload"
        log_message "Copied to clipboard"
      else
        cat "$payload"
      fi
      ;;
    *)
      echo "ERROR: unknown destination: $DESTINATION" >&2
      exit 1
      ;;
  esac
}

show_backends() {
  local selected="unavailable"

  if selected="$(select_auto_backend 2>/dev/null)"; then
    :
  else
    selected="unavailable"
  fi

  cat <<INFO
catcopy backend report

Environment:
  WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-unset}
  DISPLAY=${DISPLAY:-unset}
  XDG_SESSION_TYPE=${XDG_SESSION_TYPE:-unset}

Priority:
  CATCOPY_PRIORITY=${CATCOPY_PRIORITY:-$DEFAULT_PRIORITY}

Detected backends:
  wl-copy: $(backend_available wl-copy && echo available || echo unavailable)
  xclip:   $(backend_available xclip && echo available || echo unavailable)
  xsel:    $(backend_available xsel && echo available || echo unavailable)
  pbcopy:  $(backend_available pbcopy && echo available || echo unavailable)

Selected auto backend:
  $selected

Remote defaults:
  C_REMOTE_DISPLAY=${DEFAULT_REMOTE_DISPLAY}
  C_REMOTE_SESSION=${DEFAULT_REMOTE_SESSION}
INFO
}

clean_terminal_output() {
  python3 -c '
import re
import sys

data = sys.stdin.buffer.read().decode("utf-8", "replace")

data = re.sub(r"\x1b\][^\a]*(?:\a|\x1b\\)", "", data)
data = re.sub(r"\x1b\[[0-9;?]*[ -/]*[@-~]", "", data)
data = re.sub(r"\x1b[P^_].*?\x1b\\", "", data, flags=re.S)
data = re.sub(r"\x1b[@-Z\\-_]", "", data)

cleaned = []
for line in data.split("\n"):
    if "\r" in line:
        line = line.split("\r")[-1]
    line = re.sub(r"^[⠁⠂⠄⡀⢀⠠⠐⠈⠙⠹⠸⠼⠴⠦⠧⠇⠏]\s*", "", line)
    cleaned.append(line)

out = "\n".join(cleaned)
out = re.sub(r"[\x08\x0b\x0c]", "", out)
sys.stdout.write(out)
'
}

show_help() {
  cat <<'HELP'
catcopy / c

Purpose:
  Capture text payloads from files, stdin, commands, or command batches
  and send them to a useful destination.

Sources:
  c <file> [file2 ...]
      Capture one or more files with transport headers.

  command | c
      Capture stdin directly.

  c -- <command> [args ...]
      Run command and capture stdout raw.

Destinations:
  default
      Copy to local clipboard when available.
      If no clipboard is available, print to stdout.

  --stdout
      Print captured payload to stdout only.

  --clipboard
      Force local clipboard. Error if unavailable.

  --to HOST
      Send captured payload to HOST over SSH and copy there.

Examples:
  c README.md

  git diff | c

  c -- jq '.' data.json

  c --stdout README.md

  c --clipboard README.md

  c --to turbopi README.md

  c --to 100.87.218.21 -- hostnamectl

Batch mode:
  c --batch <name> --clear
      Clear a named batch.

  c --batch <name> -- <command> [args ...]
      Run command, append cleaned stdout+stderr to the named batch,
      and copy/send the entire batch.

  c --batch <name> --show
      Copy/send the current batch contents.

  c --batch <name> --path
      Print the batch file path.

Options:
  --backends
      Show detected clipboard backends, environment variables, priority order,
      selected auto backend, and remote defaults.

  --backend <name>
      Select clipboard backend explicitly.

      Supported backends:
        auto
        wl-copy
        xclip
        xsel
        pbcopy

Environment:
  CATCOPY_PRIORITY
      Optional comma-separated auto backend priority override.

      Example:
        CATCOPY_PRIORITY=xsel,xclip,wl-copy,pbcopy c README.md

  C_REMOTE_DISPLAY
      Display used when copying to a remote X11 clipboard.
      Default: :0.0

  C_REMOTE_SESSION
      XDG_SESSION_TYPE used for remote copy.
      Default: x11

Notes:
  File mode adds transport headers.
  Stdin and normal command mode capture raw output.
  Batch mode removes common ANSI terminal control sequences.
  Remote mode requires SSH access to HOST and a working catcopy install there.
HELP
}

copy_files() {
  mkdir -p "$STATE_DIR"

  local tmp_payload
  tmp_payload="$(mktemp "$STATE_DIR/files.XXXXXX")"

  {
    for file in "$@"; do
      if [[ ! -f "$file" ]]; then
        echo "ERROR: file not found: $file" >&2
        rm -f "$tmp_payload"
        exit 1
      fi

      echo "===== TRANSPORT HEADER (NOT PART OF FILE) ====="
      echo "PATH: $file"
      echo "NOTE: Do NOT include this header in any saved documents."
      echo "==============================================="
      cat "$file"
      echo
    done
  } > "$tmp_payload"

  copy_payload_file "$tmp_payload"
  rm -f "$tmp_payload"

  log_message "Captured file(s): $*"
}

copy_stdin() {
  mkdir -p "$STATE_DIR"

  local tmp_payload
  tmp_payload="$(mktemp "$STATE_DIR/stdin.XXXXXX")"

  cat > "$tmp_payload"
  copy_payload_file "$tmp_payload"
  rm -f "$tmp_payload"

  log_message "Captured stdin"
}

copy_command() {
  mkdir -p "$STATE_DIR"

  local tmp_payload
  tmp_payload="$(mktemp "$STATE_DIR/command.XXXXXX")"

  "$@" > "$tmp_payload"
  copy_payload_file "$tmp_payload"
  rm -f "$tmp_payload"

  log_message "Captured command output: $*"
}

batch_path() {
  local name="$1"
  mkdir -p "$STATE_DIR"

  if [[ ! "$name" =~ ^[A-Za-z0-9._-]+$ ]]; then
    echo "ERROR: invalid batch name: $name" >&2
    echo "Use only letters, numbers, dot, underscore, and dash." >&2
    exit 1
  fi

  echo "$STATE_DIR/${name}.txt"
}

batch_clear() {
  local name="$1"
  local path
  path="$(batch_path "$name")"

  : > "$path"
  log_message "Cleared batch: $name"
  log_message "Path: $path"
}

batch_show() {
  local name="$1"
  local path
  path="$(batch_path "$name")"

  if [[ ! -f "$path" ]]; then
    echo "ERROR: batch does not exist: $name" >&2
    exit 1
  fi

  copy_payload_file "$path"
  log_message "Captured batch: $name"
}

batch_command() {
  local name="$1"
  shift

  local path
  path="$(batch_path "$name")"

  local tmp_output
  tmp_output="$(mktemp "$STATE_DIR/${name}.cmd.XXXXXX")"

  local status=0
  TERM=dumb NO_COLOR=1 COLUMNS=100000 "$@" 2>&1 | clean_terminal_output > "$tmp_output" || status=$?

  {
    echo "===== COMMAND ====="
    printf '%q ' "$@"
    echo
    echo "===== EXIT STATUS ====="
    echo "$status"
    echo "===== OUTPUT ====="
    cat "$tmp_output"
    echo
  } >> "$path"

  rm -f "$tmp_output"

  copy_payload_file "$path"

  log_message "Appended command output to batch: $name"
  log_message "Captured full batch: $path"

  return "$status"
}

handle_batch() {
  local name="$1"
  shift

  if [[ $# -eq 0 ]]; then
    echo "ERROR: missing batch operation" >&2
    exit 1
  fi

  case "${1:-}" in
    --clear)
      batch_clear "$name"
      ;;
    --show)
      batch_show "$name"
      ;;
    --path)
      batch_path "$name"
      ;;
    --)
      shift
      if [[ $# -eq 0 ]]; then
        echo "ERROR: missing command after --" >&2
        exit 1
      fi
      batch_command "$name" "$@"
      ;;
    *)
      echo "ERROR: unknown batch operation: $1" >&2
      exit 1
      ;;
  esac
}

parse_global_options() {
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --stdout)
        DESTINATION="stdout"
        shift
        ;;
      --clipboard)
        DESTINATION="clipboard"
        shift
        ;;
      --to)
        shift
        if [[ $# -eq 0 ]]; then
          echo "ERROR: missing host after --to" >&2
          exit 1
        fi
        DESTINATION="remote"
        REMOTE_HOST="$1"
        shift
        ;;
      --backends)
        SHOW_BACKENDS=1
        shift
        ;;
      --backend)
        shift
        if [[ $# -eq 0 ]]; then
          echo "ERROR: missing backend name after --backend" >&2
          exit 1
        fi
        BACKEND="$1"
        shift
        ;;
      *)
        break
        ;;
    esac
  done

  MAIN_ARGS=("$@")
}

main() {
  declare -a MAIN_ARGS
  parse_global_options "$@"
  set -- "${MAIN_ARGS[@]}"

  if [[ "$SHOW_BACKENDS" -eq 1 ]]; then
    show_backends
    exit 0
  fi

  if [[ $# -eq 0 ]]; then
    if [[ -t 0 ]]; then
      show_help >&2
      exit 1
    fi

    copy_stdin
    exit 0
  fi

  case "${1:-}" in
    -h|--help|help)
      show_help
      ;;
    --batch)
      shift
      if [[ $# -eq 0 ]]; then
        echo "ERROR: missing batch name" >&2
        exit 1
      fi
      local name="$1"
      shift
      handle_batch "$name" "$@"
      ;;
    --)
      shift
      if [[ $# -eq 0 ]]; then
        echo "ERROR: missing command after --" >&2
        exit 1
      fi
      copy_command "$@"
      ;;
    *)
      copy_files "$@"
      ;;
  esac
}

main "$@"
