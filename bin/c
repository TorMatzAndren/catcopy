#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${TMPDIR:-/tmp}/catcopy-${USER:-user}"

clipboard_copy() {
  if [[ -n "${WAYLAND_DISPLAY:-}" ]] && command -v wl-copy >/dev/null 2>&1; then
    wl-copy
  elif [[ -n "${DISPLAY:-}" ]] && command -v xclip >/dev/null 2>&1; then
    xclip -selection clipboard
  elif [[ -n "${DISPLAY:-}" ]] && command -v xsel >/dev/null 2>&1; then
    xsel --clipboard --input
  elif command -v pbcopy >/dev/null 2>&1; then
    pbcopy
  elif command -v wl-copy >/dev/null 2>&1; then
    wl-copy
  elif command -v xclip >/dev/null 2>&1; then
    xclip -selection clipboard
  elif command -v xsel >/dev/null 2>&1; then
    xsel --clipboard --input
  else
    echo "ERROR: no supported clipboard backend found." >&2
    echo "Install one of: wl-clipboard, xclip, xsel." >&2
    echo "Detected DISPLAY=${DISPLAY:-unset}, WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-unset}" >&2
    exit 1
  fi
}

clean_terminal_output() {
  python3 -c '
import re
import sys

data = sys.stdin.buffer.read().decode("utf-8", "replace")

data = re.sub(r"\x1b\][^\a]*(?:\a|\x1b\\)", "", data)
data = re.sub(r"\x1b\[[0-9;?]*[ -/]*[@-~]", "", data)
data = re.sub(r"\x1b[P^_].*?\x1b\\", "", data, flags=re.S)
data = re.sub(r"\x1b[@-Z\\-_]", "", data)

cleaned = []
for line in data.split("\n"):
    if "\r" in line:
        line = line.split("\r")[-1]
    line = re.sub(r"^[⠁⠂⠄⡀⢀⠠⠐⠈⠙⠹⠸⠼⠴⠦⠧⠇⠏]\s*", "", line)
    cleaned.append(line)

out = "\n".join(cleaned)
out = re.sub(r"[\x08\x0b\x0c]", "", out)
sys.stdout.write(out)
'
}

show_help() {
  cat <<'HELP'
catcopy / c

Purpose:
  Copy files, stdin, command output, or grouped command batches to clipboard.

Usage:
  c <file> [file2 ...]
      Copy one or more files with transport headers.

  command | c
      Copy stdin directly to clipboard.

  c -- <command> [args ...]
      Run command and copy stdout to clipboard.

  c --batch <name> --clear
      Clear a named batch.

  c --batch <name> -- <command> [args ...]
      Run command, append cleaned stdout+stderr to the named batch,
      and copy the entire batch to clipboard.

  c --batch <name> --show
      Copy the current batch contents to clipboard.

  c --batch <name> --path
      Print the batch file path.

Clipboard backend priority:
  Wayland session: wl-copy
  X11 session: xclip, then xsel
  macOS fallback: pbcopy
  Generic fallback: wl-copy, xclip, xsel

Notes:
  File mode adds transport headers.
  Stdin and normal command mode copy raw output.
  Batch mode removes common ANSI terminal control sequences.
HELP
}

copy_files() {
  {
    for file in "$@"; do
      if [[ ! -f "$file" ]]; then
        echo "ERROR: file not found: $file" >&2
        exit 1
      fi

      echo "===== TRANSPORT HEADER (NOT PART OF FILE) ====="
      echo "PATH: $file"
      echo "NOTE: Do NOT include this header in any saved documents."
      echo "==============================================="
      cat "$file"
      echo
    done
  } | clipboard_copy

  echo "Copied file(s) to clipboard: $*"
}

copy_stdin() {
  cat | clipboard_copy
  echo "Copied stdin to clipboard"
}

copy_command() {
  "$@" | clipboard_copy
  echo "Copied command output to clipboard: $*"
}

batch_path() {
  local name="$1"
  mkdir -p "$STATE_DIR"

  if [[ ! "$name" =~ ^[A-Za-z0-9._-]+$ ]]; then
    echo "ERROR: invalid batch name: $name" >&2
    echo "Use only letters, numbers, dot, underscore, and dash." >&2
    exit 1
  fi

  echo "$STATE_DIR/${name}.txt"
}

batch_clear() {
  local name="$1"
  local path
  path="$(batch_path "$name")"

  : > "$path"
  echo "Cleared batch: $name"
  echo "Path: $path"
}

batch_show() {
  local name="$1"
  local path
  path="$(batch_path "$name")"

  if [[ ! -f "$path" ]]; then
    echo "ERROR: batch does not exist: $name" >&2
    exit 1
  fi

  cat "$path" | clipboard_copy
  echo "Copied batch to clipboard: $name"
}

batch_command() {
  local name="$1"
  shift

  local path
  path="$(batch_path "$name")"

  local tmp_output
  tmp_output="$(mktemp "$STATE_DIR/${name}.cmd.XXXXXX")"

  local status=0
  TERM=dumb NO_COLOR=1 COLUMNS=100000 "$@" 2>&1 | clean_terminal_output > "$tmp_output" || status=$?

  {
    echo "===== COMMAND ====="
    printf '%q ' "$@"
    echo
    echo "===== EXIT STATUS ====="
    echo "$status"
    echo "===== OUTPUT ====="
    cat "$tmp_output"
    echo
  } >> "$path"

  rm -f "$tmp_output"

  cat "$path" | clipboard_copy

  echo "Appended command output to batch: $name"
  echo "Copied full batch to clipboard: $path"

  return "$status"
}

handle_batch() {
  local name="$1"
  shift

  if [[ $# -eq 0 ]]; then
    echo "ERROR: missing batch operation" >&2
    exit 1
  fi

  case "${1:-}" in
    --clear)
      batch_clear "$name"
      ;;
    --show)
      batch_show "$name"
      ;;
    --path)
      batch_path "$name"
      ;;
    --)
      shift
      if [[ $# -eq 0 ]]; then
        echo "ERROR: missing command after --" >&2
        exit 1
      fi
      batch_command "$name" "$@"
      ;;
    *)
      echo "ERROR: unknown batch operation: $1" >&2
      exit 1
      ;;
  esac
}

main() {
  if [[ $# -eq 0 ]]; then
    if [[ -t 0 ]]; then
      show_help >&2
      exit 1
    fi

    copy_stdin
    exit 0
  fi

  case "${1:-}" in
    -h|--help|help)
      show_help
      ;;
    --batch)
      shift
      if [[ $# -eq 0 ]]; then
        echo "ERROR: missing batch name" >&2
        exit 1
      fi
      local name="$1"
      shift
      handle_batch "$name" "$@"
      ;;
    --)
      shift
      if [[ $# -eq 0 ]]; then
        echo "ERROR: missing command after --" >&2
        exit 1
      fi
      copy_command "$@"
      ;;
    *)
      copy_files "$@"
      ;;
  esac
}

main "$@"
